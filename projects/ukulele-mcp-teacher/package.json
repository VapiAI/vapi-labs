{
  "name": "ukulele-mcp-teacher",
  "version": "0.1.0",
  "description": "Vapi Labs demo of a voice-led ukulele practice app using MCP Apps and browser chord feedback.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/VapiAI/vapi-labs.git",
    "directory": "projects/ukulele-mcp-teacher"
  },
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "concurrently -n app,mcp -c cyan,magenta \"vite --host 0.0.0.0\" \"tsx watch server/index.ts\"",
    "dev:app": "vite --host 0.0.0.0",
    "dev:mcp": "tsx watch server/index.ts",
    "assistant:config": "tsx scripts/create-vapi-assistant.ts --dry-run",
    "assistant:create": "tsx scripts/create-vapi-assistant.ts",
    "assistant:update": "tsx scripts/create-vapi-assistant.ts --update",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "check": "npm test && npm run typecheck && npm run build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vapi-ai/web": "^2.4.0",
    "@xstate/react": "^6.1.0",
    "dotenv": "^17.2.3",
    "hono": "^4.10.7",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xstate": "^5.31.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
