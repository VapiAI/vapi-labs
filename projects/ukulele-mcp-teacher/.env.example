# Copy this file to .env and fill in these three values. Never commit real keys.

# Private server-side Vapi API key used only by the assistant setup script.
# Never expose this in frontend code.
VAPI_API_KEY=

# Public Vapi web key used by @vapi-ai/web to start browser calls.
# This is safe for client-side use.
VITE_VAPI_PUBLIC_KEY=

# Public HTTPS endpoint for this project's MCP server.
# For local development, expose npm run dev:mcp with a tunnel and use its /mcp URL.
VAPI_MCP_SERVER_URL=
